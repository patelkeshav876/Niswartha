# MongoDB Atlas (required for API)
MONGODB_URI=mongodb+srv://Asra:keshav123@cluster0.9rkfuwe.mongodb.net/appName=Cluster0

# API port (default 4000). Vite dev proxy uses this same value (see vite.config.ts).
PORT=4000

# Frontend: base URL for REST API (Vite dev proxies /api → http://127.0.0.1:$PORT)
VITE_API_URL=/api

# Visit booking OTP: set to 1 to return devCode in POST /api/visit-otp/send (local testing only).
# Replace with SMS provider in production.
VISIT_OTP_DEV=1

# Unsplash (optional — image search in admin Create Event / Manage Needs)
# https://unsplash.com/oauth/applications
VITE_UNSPLASH_ACCESS_KEY=

